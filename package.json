{
  "name": "rum-runner-rhapsody",
  "version": "0.0.1",
  "description": "A dual-output soundboard for Windows. Plays audio to headphones and a virtual cable simultaneously.",
  "main": "dist-electron/main.js",
  "author": "Pdog1",
  "scripts": {
    "dev": "vite",
    "typecheck": "vue-tsc --noEmit",
    "build": "vue-tsc --noEmit && vite build && electron-builder --win portable",
    "build:installer": "vue-tsc --noEmit && vite build && electron-builder --win nsis"
  },
  "license": "MIT",
  "dependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^25.3.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.29.0",
    "vue-tsc": "^3.2.5"
  },
  "build": {
    "appId": "com.rum-runner-rhapsody.app",
    "productName": "Rum-Runner Rhapsody",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "app-icon.png"
    },
    "portable": {
      "artifactName": "Rum-Runner-Rhapsody.exe"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "artifactName": "RRR-Setup.exe"
    },
    "extraResources": []
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
